# C-Goldfish-Termination-Suite — Integration Environment Variables
# Copy to .env and fill in your values
# ProjectForge v1.3

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO=goatpants24/truelister-docs
GITHUB_BRANCH=main

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Recipient email for state sync notifications
GMAIL_TO=your@email.com

# ── LINE ──────────────────────────────────────────────────────────────────────
# LINE user ID to push state sync messages to
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive ──────────────────────────────────────────────────────────────
# rclone remote path for STATE.json backup
GDRIVE_FOLDER=manus_google_drive:ProjectForge
RCLONE_CONFIG=/home/ubuntu/.gdrive-rclone.ini
